local function CreatePlayerSelect(parentPage, name, glowColor, callback)
    local Frame = Instance.new("Frame")
    Frame.Parent = parentPage
    Frame.BackgroundColor3 = Color3.fromRGB(10, 15, 30)
    Frame.BackgroundTransparency = 0.2
    Frame.BorderSizePixel = 0
    Frame.Size = UDim2.new(1, -10, 0, 40)
    Frame.ZIndex = 3
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = Frame
    
    local Glow = Instance.new("UIStroke")
    Glow.Parent = Frame
    Glow.Color = glowColor
    Glow.Thickness = 1.5
    Glow.Transparency = 0.5

    local Title = Instance.new("TextLabel")
    Title.Parent = Frame
    Title.BackgroundTransparency = 1
    Title.Position = UDim2.new(0, 10, 0, 0)
    Title.Size = UDim2.new(0.35, 0, 1, 0)
    Title.Font = Enum.Font.GothamSemibold
    Title.Text = name
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.ZIndex = 3
    MakeTextNeonWhite(Title)

    local PrevBtn = Instance.new("TextButton")
    PrevBtn.Parent = Frame
    PrevBtn.BackgroundColor3 = Color3.fromRGB(20, 30, 50)
    PrevBtn.Position = UDim2.new(0.4, 0, 0.15, 0)
    PrevBtn.Size = UDim2.new(0.1, 0, 0.7, 0)
    PrevBtn.Font = Enum.Font.GothamBold
    PrevBtn.Text = "<"
    PrevBtn.TextSize = 14
    PrevBtn.ZIndex = 3
    MakeTextNeonWhite(PrevBtn)
    local pCorner = Instance.new("UICorner") pCorner.CornerRadius = UDim.new(0, 4) pCorner.Parent = PrevBtn

    local NextBtn = Instance.new("TextButton")
    NextBtn.Parent = Frame
    NextBtn.BackgroundColor3 = Color3.fromRGB(20, 30, 50)
    NextBtn.Position = UDim2.new(0.85, 0, 0.15, 0)
    NextBtn.Size = UDim2.new(0.1, 0, 0.7, 0)
    NextBtn.Font = Enum.Font.GothamBold
    NextBtn.Text = ">"
    NextBtn.TextSize = 14
    NextBtn.ZIndex = 3
    MakeTextNeonWhite(NextBtn)
    local nCorner = Instance.new("UICorner") nCorner.CornerRadius = UDim.new(0, 4) nCorner.Parent = NextBtn

    local TargetLbl = Instance.new("TextLabel")
    TargetLbl.Parent = Frame
    TargetLbl.BackgroundTransparency = 1
    TargetLbl.Position = UDim2.new(0.5, 0, 0, 0)
    TargetLbl.Size = UDim2.new(0.35, 0, 1, 0)
    TargetLbl.Font = Enum.Font.Gotham
    TargetLbl.Text = "None"
    TargetLbl.TextSize = 12
    TargetLbl.ZIndex = 3
    MakeTextNeonWhite(TargetLbl)

    local currentIndex = 1
    
    local function getTarget()
        local plrs = Players:GetPlayers()
        local valid = {}
        for _, p in pairs(plrs) do
            if p ~= player then
                table.insert(valid, p)
            end
        end
        return valid
    end

    local function updateSelection()
        local valid = getTarget()
        if #valid == 0 then
            TargetLbl.Text = "No Players"
            callback(nil)
            return
        end
        
        if currentIndex > #valid then currentIndex = 1 end
        if currentIndex < 1 then currentIndex = #valid end
        
        local selected = valid[currentIndex]
        TargetLbl.Text = selected.Name
        callback(selected)
    end

    PrevBtn.MouseButton1Click:Connect(function()
        currentIndex = currentIndex - 1
        updateSelection()
    end)

    NextBtn.MouseButton1Click:Connect(function()
        currentIndex = currentIndex + 1
        updateSelection()
    end)

    -- Click the label to refresh the list just in case
    local RefreshBtn = Instance.new("TextButton")
    RefreshBtn.Parent = Frame
    RefreshBtn.BackgroundTransparency = 1
    RefreshBtn.Position = TargetLbl.Position
    RefreshBtn.Size = TargetLbl.Size
    RefreshBtn.Text = ""
    RefreshBtn.ZIndex = 4
    RefreshBtn.MouseButton1Click:Connect(updateSelection)

    updateSelection()
end

