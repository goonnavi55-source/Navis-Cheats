-- Static Twinkling Stars (more subtle)
local function createStar()
    local star = Instance.new("Frame")
    star.Parent = bgContainer
    star.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    local size = math.random(1, 2)
    star.Size = UDim2.new(0, size, 0, size)
    star.Position = UDim2.new(math.random(), 0, math.random(), 0)
    star.BorderSizePixel = 0
    star.ZIndex = 0
    star.BackgroundTransparency = 0.5
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = star
    
    task.spawn(function()
        while star and star.Parent do
            local tweenInfo = TweenInfo.new(math.random(3, 6), Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            local tween = TweenService:Create(star, tweenInfo, {BackgroundTransparency = math.random(7, 10)/10})
            tween:Play()
            tween.Completed:Wait()
            
            local tweenInfo2 = TweenInfo.new(math.random(3, 6), Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            local tween2 = TweenService:Create(star, tweenInfo2, {BackgroundTransparency = 0.3})
            tween2:Play()
            tween2.Completed:Wait()
        end
    end)
end

for i = 1, 50 do
    createStar()
end

-- Shooting Stars (more subtle)
local function createShootingStar()
    local sStar = Instance.new("Frame")
    sStar.Parent = bgContainer
    sStar.BackgroundColor3 = Color3.fromRGB(150, 200, 255)
    sStar.BackgroundTransparency = 0.4
    sStar.BorderSizePixel = 0
    sStar.Size = UDim2.new(0, math.random(20, 60), 0, 1)
    
    local angle = math.random(30, 60)
    sStar.Rotation = angle
    sStar.ZIndex = 0
    
    local startX = (math.random(20, 150) / 100) 
    local startY = -0.2
    sStar.Position = UDim2.new(startX, 0, startY, 0)
    
    local endPos = UDim2.new(startX - 1.5, 0, 1.5, 0) 
    
    local tweenInfo = TweenInfo.new(math.random(8, 20)/10, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(sStar, tweenInfo, {Position = endPos})
    tween:Play()
    
    tween.Completed:Connect(function()
        sStar:Destroy()
    end)
end

task.spawn(function()
    while bgContainer and bgContainer.Parent do
        task.wait(math.random(20, 50) / 10) 
        createShootingStar()
    end
end)

